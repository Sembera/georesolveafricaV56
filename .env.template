# Contentful Configuration
VITE_CONTENTFUL_SPACE_ID=your_space_id_here
VITE_CONTENTFUL_ACCESS_TOKEN=your_access_token_here
VITE_CONTENTFUL_ENVIRONMENT=master

# Optional: Contentful Preview API (for development)
VITE_CONTENTFUL_PREVIEW_TOKEN=your_preview_token_here

# Optional: Analytics and other integrations
VITE_GOOGLE_ANALYTICS_ID=
VITE_HOTJAR_ID=

# WP12-B: Brevo mailing list (used by netlify/functions/subscribe.js)
# Create an API key at https://app.brevo.com/settings/keys/api (v3).
# LIST_ID is the numeric ID of the list that site signups are added to.
# Also set these as Netlify build environment variables (Site settings -> Environment variables).
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=your_brevo_list_id_here